  "instructions": [
    { "id": "step-001", "step_number": 1, "instruction_text": "Preheat oven to 350 degrees F (175 degrees C)." },
    { "id": "step-002", "step_number": 2, "instruction_text": "Cream together the butter, white sugar, and brown sugar until smooth." },
    { "id": "step-003", "step_number": 3, "instruction_text": "Beat in the eggs one at a time, then stir in the vanilla." },
    { "id": "step-004", "step_number": 4, "instruction_text": "Dissolve baking soda in hot water. Add to batter along with salt." },
    { "id": "step-005", "step_number": 5, "instruction_text": "Stir in flour, chocolate chips, and nuts." },
    { "id": "step-006", "step_number": 6, "instruction_text": "Drop large spoonfuls onto ungreased pans." },
    { "id": "step-007", "step_number": 7, "instruction_text": "Bake for about 10 minutes in the preheated oven, or until edges are nicely browned." }
